{
  "name": "@conduit-harness/conduit",
  "version": "0.1.0-preview.1",
  "description": "Conduit: a TypeScript implementation of the Symphony service specification",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conduit-harness/conduit.git"
  },
  "bugs": {
    "url": "https://github.com/conduit-harness/conduit/issues"
  },
  "homepage": "https://github.com/conduit-harness/conduit#readme",
  "type": "module",
  "bin": {
    "conduit": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "examples",
    ".conduit/workflow.example.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "tsx src/cli/index.ts validate --workflow .conduit/workflow.example.md",
    "prepack": "npm run build",
    "package:smoke": "npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "dotenv": "latest",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@conduit-harness/conduit-runner-aider": "workspace:*",
    "@conduit-harness/conduit-runner-claude-cli": "workspace:*",
    "@conduit-harness/conduit-runner-codex-cli": "workspace:*",
    "@conduit-harness/conduit-tracker-github": "workspace:*",
    "@conduit-harness/conduit-tracker-gitlab": "workspace:*",
    "@conduit-harness/conduit-tracker-jira": "workspace:*",
    "@conduit-harness/conduit-tracker-linear": "workspace:*",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
