# Copy to .env for local runs. .env is git-ignored.

# Required for the github tracker (.conduit/workflow.md uses this).
# Personal access token with `repo` scope (or fine-grained: Issues read,
# Contents read, plus write if you flip writes.enabled to true).
GITHUB_TOKEN=

LINEAR_API_KEY=
# OPENAI_API_KEY may be required by your installed Codex CLI.
OPENAI_API_KEY=
