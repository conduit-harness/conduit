{
  "name": "@conduit-harness/conduit-runner-openai-api",
  "version": "0.0.1",
  "description": "Conduit agent runner plugin for OpenAI-compatible APIs (OpenAI, Azure, GitHub Models)",
  "type": "module",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=24.0.0" },
  "peerDependencies": { "@conduit-harness/conduit": ">=0.0.1" },
  "devDependencies": {
    "@conduit-harness/conduit": "workspace:*",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
