{
  "name": "@conduit-harness/conduit-tracker-github",
  "version": "0.0.2-rc2",
  "description": "Conduit tracker plugin for GitHub Issues",
  "type": "module",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "git+https://github.com/conduit-harness/conduit.git" },
  "engines": { "node": ">=24.0.0" },
  "peerDependencies": { "@conduit-harness/conduit": ">=0.0.2-rc2" },
  "devDependencies": {
    "@conduit-harness/conduit": "workspace:*",
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
