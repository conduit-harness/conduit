---
// Interactive setup wizard. State is managed client-side; the component is a
// static shell that the script wires up.
---

<div class="wizard" data-wizard>
  <ol class="wizard-steps">
    <li>
      <h3>1. Pick a tracker</h3>
      <div class="choices" role="radiogroup" aria-label="Tracker">
        <label><input type="radio" name="tracker" value="github" checked /> <span>GitHub Issues</span></label>
        <label><input type="radio" name="tracker" value="linear" /> <span>Linear</span></label>
        <label><input type="radio" name="tracker" value="jira" /> <span>Jira</span></label>
        <label><input type="radio" name="tracker" value="gitlab" /> <span>GitLab</span></label>
      </div>
      <div class="tracker-fields">
        <div data-tracker-field="github">
          <label>Repository <code>owner/name</code>
            <input type="text" data-input="github.repo" placeholder="acme/widgets" value="acme/widgets" />
          </label>
        </div>
        <div data-tracker-field="linear" hidden>
          <label>Team key
            <input type="text" data-input="linear.team_key" placeholder="ENG" value="ENG" />
          </label>
        </div>
        <div data-tracker-field="jira" hidden>
          <label>Base URL
            <input type="text" data-input="jira.base_url" placeholder="https://your-org.atlassian.net" value="https://your-org.atlassian.net" />
          </label>
          <label>Project key
            <input type="text" data-input="jira.project_key" placeholder="PROJ" value="PROJ" />
          </label>
        </div>
        <div data-tracker-field="gitlab" hidden>
          <label>Project ID
            <input type="text" data-input="gitlab.project_id" placeholder="12345" value="12345" />
          </label>
        </div>
      </div>
    </li>

    <li>
      <h3>2. Pick a runner</h3>
      <div class="choices" role="radiogroup" aria-label="Runner">
        <label><input type="radio" name="runner" value="claude-cli" checked /> <span>Claude Code CLI</span></label>
        <label><input type="radio" name="runner" value="codex-cli" /> <span>OpenAI Codex CLI</span></label>
        <label><input type="radio" name="runner" value="aider" /> <span>Aider (Ollama, self-hosted)</span></label>
        <label><input type="radio" name="runner" value="claude-api" /> <span>Claude API (deprecated — no harness)</span></label>
        <label><input type="radio" name="runner" value="openai-api" /> <span>OpenAI-compatible API (deprecated — no harness)</span></label>
      </div>
      <div class="runner-fields">
        <div data-runner-field="claude-cli">
          <label>Model
            <input type="text" data-input="claude-cli.model" value="claude-sonnet-4-6" />
          </label>
        </div>
        <div data-runner-field="claude-api" hidden>
          <label>Model
            <input type="text" data-input="claude-api.model" value="claude-sonnet-4-6" />
          </label>
        </div>
        <div data-runner-field="openai-api" hidden>
          <label>Model
            <input type="text" data-input="openai-api.model" value="gpt-4o" />
          </label>
          <label>Base URL
            <input type="text" data-input="openai-api.base_url" value="https://api.openai.com/v1" />
          </label>
        </div>
        <div data-runner-field="codex-cli" hidden>
          <label>Model
            <input type="text" data-input="codex-cli.model" value="gpt-5" />
          </label>
        </div>
        <div data-runner-field="aider" hidden>
          <label>Model
            <input type="text" data-input="aider.model" value="ollama_chat/qwen2.5-coder:14b" />
          </label>
          <label>Ollama endpoint
            <input type="text" data-input="aider.ollama_endpoint" value="http://localhost:11434" />
          </label>
        </div>
      </div>

      <div class="hardware" data-hardware-section hidden>
        <h4>Hardware</h4>
        <div class="choices" role="radiogroup" aria-label="Inference mode">
          <label><input type="radio" name="inference_mode" value="cpu" checked /> <span>CPU</span></label>
          <label><input type="radio" name="inference_mode" value="gpu" /> <span>GPU</span></label>
        </div>
        <div class="hardware-fields">
          <label>CPU vendor
            <select data-input="hardware.cpu_vendor">
              <option value="intel">Intel</option>
              <option value="amd">AMD</option>
              <option value="qualcomm">Qualcomm</option>
              <option value="apple">Apple</option>
            </select>
          </label>
          <label>CPU series
            <select data-input="hardware.cpu_series" data-cpu-series></select>
          </label>
          <label data-gpu-only hidden>GPU vendor
            <select data-input="hardware.gpu_vendor">
              <option value="nvidia">NVIDIA</option>
              <option value="amd">AMD</option>
              <option value="intel">Intel</option>
            </select>
          </label>
          <label data-gpu-only hidden>GPU series
            <select data-input="hardware.gpu_series" data-gpu-series></select>
          </label>
          <label>RAM (GB): <output data-ram-display>16</output>
            <input type="range" min="0" max="11" step="1" value="5" data-ram-input />
          </label>
        </div>

        <div class="benchmark" data-benchmark>
          <div class="benchmark-line">
            Recommended model: <code data-output="benchmark-model">qwen2.5-coder:7b</code>
          </div>
          <div class="benchmark-line">
            Pessimistic throughput: <strong data-output="benchmark-tps">~20 tok/s</strong>
            <span class="benchmark-note">floor estimate; verify on your hardware</span>
          </div>
        </div>
      </div>
    </li>

    <li>
      <h3>3. Pick a workflow template</h3>
      <div class="choices" role="radiogroup" aria-label="Workflow template">
        <label><input type="radio" name="template" value="autonomous" checked /> <span>Autonomous</span></label>
        <label><input type="radio" name="template" value="human-in-the-loop" /> <span>Human-in-the-loop</span></label>
        <label><input type="radio" name="template" value="reply-draft" /> <span>Customer reply (non-coding)</span></label>
      </div>
      <p class="template-hint" data-template-hint="autonomous">Agent runs to completion: comments and transitions the issue through every lifecycle event.</p>
      <p class="template-hint" data-template-hint="human-in-the-loop" hidden>Agent investigates and prepares the change, then transitions the issue to a review state for a human to take over.</p>
      <p class="template-hint" data-template-hint="reply-draft" hidden>Agent drafts a reply for a human to review and send. No code changes, no state transitions.</p>
    </li>

    <li>
      <h3>4. Install</h3>
      <pre><code data-output="install"></code></pre>
      <button type="button" data-copy="install">Copy</button>
    </li>

    <li>
      <h3>5. <code>.conduit/workflow.md</code></h3>
      <pre><code data-output="workflow"></code></pre>
      <button type="button" data-copy="workflow">Copy</button>
    </li>

    <li>
      <h3>6. <code>.env</code></h3>
      <pre><code data-output="env"></code></pre>
      <button type="button" data-copy="env">Copy</button>
    </li>

    <li>
      <h3>7. Run</h3>
      <pre><code data-output="run"></code></pre>
      <button type="button" data-copy="run">Copy</button>
    </li>
  </ol>
</div>

<script>
  type TrackerKind = "github" | "linear" | "jira" | "gitlab";
  type RunnerKind = "claude-cli" | "claude-api" | "openai-api" | "codex-cli" | "aider";
  type TemplateKind = "autonomous" | "human-in-the-loop" | "reply-draft";
  type InferenceMode = "cpu" | "gpu";
  type CpuVendor = "intel" | "amd" | "qualcomm" | "apple";
  type GpuVendor = "nvidia" | "amd" | "intel";

  const CPU_SERIES_BY_VENDOR: Record<CpuVendor, Array<{ value: string; label: string }>> = {
    intel: [
      { value: "core-ultra-s2", label: "Core Ultra (Series 2)" },
      { value: "core-ultra-s1", label: "Core Ultra (Series 1)" },
      { value: "core-14th", label: "Core 14th Gen" },
      { value: "core-13th", label: "Core 13th Gen" },
      { value: "core-12th", label: "Core 12th Gen" },
      { value: "core-11th", label: "Core 11th Gen" },
      { value: "core-10th", label: "Core 10th Gen" },
    ],
    amd: [
      { value: "ryzen-9000", label: "Ryzen 9000" },
      { value: "ryzen-ai-300", label: "Ryzen AI 300" },
      { value: "ryzen-7000", label: "Ryzen 7000" },
      { value: "ryzen-5000", label: "Ryzen 5000" },
      { value: "ryzen-3000", label: "Ryzen 3000" },
    ],
    qualcomm: [
      { value: "snapdragon-x2-elite", label: "Snapdragon X2 Elite" },
      { value: "snapdragon-x-elite", label: "Snapdragon X Elite" },
      { value: "snapdragon-x-plus", label: "Snapdragon X Plus" },
    ],
    apple: [
      { value: "m4", label: "M4" },
      { value: "m3", label: "M3" },
      { value: "m2", label: "M2" },
      { value: "m1", label: "M1" },
    ],
  };

  // Pessimistic tok/s floors per memory tier on Q4_K_M quants. These are
  // intentionally conservative — they should be exceeded on most real
  // hardware in the tier. Hand-validate before publishing tighter numbers.
  type Benchmark = { ramFloor: number; model: string; gpuTps: number; cpuTps: number };
  const BENCHMARKS: Benchmark[] = [
    { ramFloor: 24, model: "qwen2.5-coder:32b", gpuTps: 6, cpuTps: 0.7 },
    { ramFloor: 12, model: "qwen2.5-coder:14b", gpuTps: 10, cpuTps: 1.5 },
    { ramFloor: 8, model: "qwen2.5-coder:7b", gpuTps: 20, cpuTps: 3 },
    { ramFloor: 4, model: "qwen2.5-coder:3b", gpuTps: 15, cpuTps: 4 },
    { ramFloor: 0, model: "qwen2.5-coder:3b", gpuTps: 12, cpuTps: 3 },
  ];

  function pickBenchmark(memGb: number): Benchmark {
    for (const b of BENCHMARKS) if (memGb >= b.ramFloor) return b;
    return BENCHMARKS[BENCHMARKS.length - 1]!;
  }

  // Discrete GPUs only — iGPUs intentionally excluded.
  const GPU_SERIES_BY_VENDOR: Record<GpuVendor, Array<{ value: string; label: string }>> = {
    nvidia: [
      { value: "rtx5xxx", label: "RTX 50xx" },
      { value: "rtx4xxx", label: "RTX 40xx" },
      { value: "rtx3xxx", label: "RTX 30xx" },
      { value: "rtx2xxx", label: "RTX 20xx" },
      { value: "gtx16xx", label: "GTX 16xx" },
      { value: "gtx10xx", label: "GTX 10xx" },
      { value: "gtx9xx", label: "GTX 9xx" },
    ],
    amd: [
      { value: "rx9xxx", label: "RX 9xxx" },
      { value: "rx7xxx", label: "RX 7xxx" },
      { value: "rx6xxx", label: "RX 6xxx" },
      { value: "rx5xxx", label: "RX 5xxx" },
      { value: "rx5xx", label: "RX 5xx" },
    ],
    intel: [
      { value: "arc-b", label: "Arc B-series" },
      { value: "arc-a", label: "Arc A-series" },
    ],
  };

  const root = document.querySelector<HTMLElement>("[data-wizard]");
  if (root) {
    const state: {
      tracker: TrackerKind;
      runner: RunnerKind;
      template: TemplateKind;
      inferenceMode: InferenceMode;
      inputs: Record<string, string>;
    } = {
      tracker: "github",
      runner: "claude-cli",
      template: "autonomous",
      inferenceMode: "cpu",
      inputs: {},
    };

    root.querySelectorAll<HTMLInputElement | HTMLSelectElement>("[data-input]").forEach((el) => {
      state.inputs[el.dataset.input!] = el.value;
      el.addEventListener("input", () => {
        state.inputs[el.dataset.input!] = el.value;
        render();
      });
      el.addEventListener("change", () => {
        state.inputs[el.dataset.input!] = el.value;
        if (el.dataset.input === "hardware.gpu_vendor") repopulateGpuSeries();
        if (el.dataset.input === "hardware.cpu_vendor") repopulateCpuSeries();
        render();
      });
    });

    const RAM_STEPS = [4, 6, 8, 10, 12, 16, 20, 24, 32, 48, 72, 96];
    const ramInput = root.querySelector<HTMLInputElement>("[data-ram-input]");
    const ramDisplay = root.querySelector<HTMLElement>("[data-ram-display]");
    function syncRam() {
      if (!ramInput) return;
      const idx = Number.parseInt(ramInput.value, 10);
      const gb = RAM_STEPS[Number.isFinite(idx) ? idx : 5] ?? 16;
      state.inputs["hardware.ram_gb"] = String(gb);
      if (ramDisplay) ramDisplay.textContent = String(gb);
    }
    if (ramInput) {
      syncRam();
      ramInput.addEventListener("input", () => {
        syncRam();
        render();
      });
    }

    root.querySelectorAll<HTMLInputElement>('input[name="inference_mode"]').forEach((el) => {
      el.addEventListener("change", () => {
        if (el.checked) {
          state.inferenceMode = el.value as InferenceMode;
          toggleHardwareFields();
          render();
        }
      });
    });

    root
      .querySelectorAll<HTMLInputElement>('input[name="tracker"]')
      .forEach((el) => {
        el.addEventListener("change", () => {
          if (el.checked) {
            state.tracker = el.value as TrackerKind;
            toggleFields();
            render();
          }
        });
      });

    root
      .querySelectorAll<HTMLInputElement>('input[name="runner"]')
      .forEach((el) => {
        el.addEventListener("change", () => {
          if (el.checked) {
            state.runner = el.value as RunnerKind;
            toggleFields();
            render();
          }
        });
      });

    root
      .querySelectorAll<HTMLInputElement>('input[name="template"]')
      .forEach((el) => {
        el.addEventListener("change", () => {
          if (el.checked) {
            state.template = el.value as TemplateKind;
            toggleFields();
            render();
          }
        });
      });

    root.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const key = btn.dataset.copy!;
        const code = root.querySelector<HTMLElement>(
          `[data-output="${key}"]`,
        );
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code.textContent ?? "");
          const original = btn.textContent;
          btn.textContent = "Copied";
          setTimeout(() => {
            btn.textContent = original;
          }, 1200);
        } catch {
          // clipboard blocked — ignore
        }
      });
    });

    function toggleFields() {
      root!
        .querySelectorAll<HTMLElement>("[data-tracker-field]")
        .forEach((el) => {
          el.hidden = el.dataset.trackerField !== state.tracker;
        });
      root!
        .querySelectorAll<HTMLElement>("[data-runner-field]")
        .forEach((el) => {
          el.hidden = el.dataset.runnerField !== state.runner;
        });
      root!
        .querySelectorAll<HTMLElement>("[data-template-hint]")
        .forEach((el) => {
          el.hidden = el.dataset.templateHint !== state.template;
        });
      const hardwareSection = root!.querySelector<HTMLElement>("[data-hardware-section]");
      if (hardwareSection) hardwareSection.hidden = state.runner !== "aider";
      toggleHardwareFields();
    }

    function toggleHardwareFields() {
      root!.querySelectorAll<HTMLElement>("[data-gpu-only]").forEach((el) => {
        el.hidden = state.inferenceMode !== "gpu";
      });
    }

    function repopulateGpuSeries() {
      const select = root!.querySelector<HTMLSelectElement>("[data-gpu-series]");
      if (!select) return;
      const vendor = (state.inputs["hardware.gpu_vendor"] as GpuVendor) || "nvidia";
      const options = GPU_SERIES_BY_VENDOR[vendor] ?? [];
      select.innerHTML = "";
      for (const opt of options) {
        const o = document.createElement("option");
        o.value = opt.value;
        o.textContent = opt.label;
        select.appendChild(o);
      }
      state.inputs["hardware.gpu_series"] = select.value;
    }

    function repopulateCpuSeries() {
      const select = root!.querySelector<HTMLSelectElement>("[data-cpu-series]");
      if (!select) return;
      const vendor = (state.inputs["hardware.cpu_vendor"] as CpuVendor) || "intel";
      const options = CPU_SERIES_BY_VENDOR[vendor] ?? [];
      select.innerHTML = "";
      for (const opt of options) {
        const o = document.createElement("option");
        o.value = opt.value;
        o.textContent = opt.label;
        select.appendChild(o);
      }
      state.inputs["hardware.cpu_series"] = select.value;
    }

    function trackerPackage(t: TrackerKind) {
      return `@conduit-harness/conduit-tracker-${t}`;
    }

    function runnerPackage(r: RunnerKind) {
      // claude-api maps onto the openai-api runner against Anthropic's
      // OpenAI-compatible endpoint, so the package is the same.
      if (r === "claude-api") return "@conduit-harness/conduit-runner-openai-api";
      return `@conduit-harness/conduit-runner-${r}`;
    }

    function buildInstall(): string {
      const pkgs = [
        "@conduit-harness/conduit",
        trackerPackage(state.tracker),
        runnerPackage(state.runner),
      ];
      return `npm install -g \\\n  ${pkgs.join(" \\\n  ")}`;
    }

    function requiredLabel(): string {
      return state.template === "reply-draft" ? "needs-reply" : "agentic";
    }

    function writesYaml(): string[] {
      const t = state.tracker;
      const tpl = state.template;

      // GitHub and GitLab have no useful in-flight transitions (states are
      // just open/closed), so we stick to comments for every event and never
      // auto-close on success.
      const transitions =
        t === "github" || t === "gitlab"
          ? null
          : t === "linear"
            ? {
                start: "In Progress",
                success: tpl === "human-in-the-loop" ? "In Review" : "Done",
                failure: "Todo",
                terminal: "Blocked",
              }
            : {
                // jira
                start: "In Progress",
                success: tpl === "human-in-the-loop" ? "In Review" : "Done",
                failure: "To Do",
                terminal: "Blocked",
              };

      if (tpl === "reply-draft") {
        return [
          "  writes:",
          "    enabled: true",
          "    on_success:",
          "      comment: true",
        ];
      }

      const lines = ["  writes:", "    enabled: true"];
      const event = (
        name: string,
        transitionTo: string | null | undefined,
      ) => {
        lines.push(`    ${name}:`);
        lines.push("      comment: true");
        if (transitionTo) lines.push(`      transition_to: ${transitionTo}`);
      };
      event("on_start", transitions?.start);
      event("on_success", transitions?.success);
      event("on_failure", transitions?.failure);
      // Terminal failure is the "we've given up" event — only HITL/autonomous
      // care, and for trackers without transitions we still want a comment.
      event("on_terminal_failure", transitions?.terminal);
      return lines;
    }

    function trackerYaml(): string {
      const t = state.tracker;
      const label = requiredLabel();
      if (t === "github") {
        return [
          "tracker:",
          "  kind: github",
          "  api_key: $GITHUB_TOKEN",
          `  repo: ${state.inputs["github.repo"] || "owner/name"}`,
          "  active_states: [open]",
          `  required_labels: [${label}]`,
          "  excluded_labels: [blocked]",
          ...writesYaml(),
        ].join("\n");
      }
      if (t === "linear") {
        return [
          "tracker:",
          "  kind: linear",
          "  api_key: $LINEAR_API_KEY",
          `  team_key: ${state.inputs["linear.team_key"] || "ENG"}`,
          "  active_states: [Todo, Ready]",
          `  required_labels: [${label}]`,
          "  excluded_labels: [blocked]",
          ...writesYaml(),
        ].join("\n");
      }
      if (t === "jira") {
        return [
          "tracker:",
          "  kind: jira",
          "  api_key: $JIRA_API_TOKEN",
          "  email: $JIRA_EMAIL",
          `  base_url: ${state.inputs["jira.base_url"] || "https://your-org.atlassian.net"}`,
          `  project_key: ${state.inputs["jira.project_key"] || "PROJ"}`,
          "  active_states: [To Do, In Progress]",
          `  required_labels: [${label}]`,
          "  excluded_labels: [blocked]",
          ...writesYaml(),
        ].join("\n");
      }
      // gitlab
      return [
        "tracker:",
        "  kind: gitlab",
        "  api_key: $GITLAB_TOKEN",
        `  project_id: ${state.inputs["gitlab.project_id"] || "12345"}`,
        "  active_states: [opened]",
        `  required_labels: [${label}]`,
        "  excluded_labels: [blocked]",
        ...writesYaml(),
      ].join("\n");
    }

    function runnerYaml(): string {
      const r = state.runner;
      if (r === "claude-cli") {
        return [
          "agent:",
          "  kind: claude-cli",
          "  max_concurrent_agents: 1",
          "claude-cli:",
          `  model: ${state.inputs["claude-cli.model"] || "claude-sonnet-4-6"}`,
        ].join("\n");
      }
      if (r === "claude-api") {
        return [
          "agent:",
          "  kind: openai-api",
          "  max_concurrent_agents: 1",
          "openai-api:",
          `  model: ${state.inputs["claude-api.model"] || "claude-sonnet-4-6"}`,
          "  base_url: https://api.anthropic.com/v1",
          "  token: $ANTHROPIC_API_KEY",
        ].join("\n");
      }
      if (r === "openai-api") {
        return [
          "agent:",
          "  kind: openai-api",
          "  max_concurrent_agents: 1",
          "openai-api:",
          `  model: ${state.inputs["openai-api.model"] || "gpt-4o"}`,
          `  base_url: ${state.inputs["openai-api.base_url"] || "https://api.openai.com/v1"}`,
          "  token: $OPENAI_API_KEY",
        ].join("\n");
      }
      if (r === "codex-cli") {
        return [
          "agent:",
          "  kind: codex-cli",
          "  max_concurrent_agents: 1",
          "codex-cli:",
          `  model: ${state.inputs["codex-cli.model"] || "gpt-5"}`,
        ].join("\n");
      }
      // aider
      const userModel = state.inputs["aider.model"];
      const model = userModel && userModel.length > 0 ? userModel : recommendedAiderModel();
      return [
        "agent:",
        "  kind: aider",
        "  max_concurrent_agents: 1",
        "aider:",
        `  model: ${model}`,
        `  ollama_endpoint: ${state.inputs["aider.ollama_endpoint"] || "http://localhost:11434"}`,
      ].join("\n");
    }

    function effectiveMemoryGb(): number {
      const n = Number.parseInt(state.inputs["hardware.ram_gb"] ?? "16", 10);
      return Number.isFinite(n) ? n : 16;
    }

    function recommendedAiderModel(): string {
      const mem = effectiveMemoryGb();
      // CPU inference is much slower; cap the model size even when system
      // RAM would technically fit something larger, otherwise the agent
      // loop becomes unusable.
      const cpuCapped = state.inferenceMode === "cpu" ? Math.min(mem, 16) : mem;
      return `ollama_chat/${pickBenchmark(cpuCapped).model}`;
    }

    function benchmarkLabel(): { model: string; tps: string } {
      const bm = pickBenchmark(effectiveMemoryGb());
      const tps = state.inferenceMode === "gpu" ? bm.gpuTps : bm.cpuTps;
      return { model: bm.model, tps: `~${tps} tok/s` };
    }

    function hardwareComment(): string | undefined {
      if (state.runner !== "aider") return undefined;
      const bm = pickBenchmark(effectiveMemoryGb());
      const tps = state.inferenceMode === "gpu" ? bm.gpuTps : bm.cpuTps;
      const lines: string[] = ["# hardware:"];
      lines.push(`#   inference: ${state.inferenceMode}`);
      lines.push(`#   cpu_vendor: ${state.inputs["hardware.cpu_vendor"] || "intel"}`);
      lines.push(`#   cpu_series: ${state.inputs["hardware.cpu_series"] || ""}`);
      if (state.inferenceMode === "gpu") {
        lines.push(`#   gpu_vendor: ${state.inputs["hardware.gpu_vendor"] || "nvidia"}`);
        lines.push(`#   gpu_series: ${state.inputs["hardware.gpu_series"] || ""}`);
      }
      lines.push(`#   ram_gb: ${state.inputs["hardware.ram_gb"] || "16"}`);
      lines.push(`# benchmark (pessimistic floor, verify by hand):`);
      lines.push(`#   model: ${bm.model}`);
      lines.push(`#   throughput_tok_s: ~${tps}`);
      return lines.join("\n");
    }

    function trackerNoun(t: TrackerKind) {
      return {
        github: "GitHub",
        linear: "Linear",
        jira: "Jira",
        gitlab: "GitLab",
      }[t];
    }

    function promptBody(): string[] {
      const noun = trackerNoun(state.tracker);
      const tpl = state.template;
      const header = [
        `Issue: {{issue.identifier}} - {{issue.title}}`,
        "URL: {{issue.url}}",
        "State: {{issue.state}}",
        "Labels: {{issue.labels}}",
        "Attempt: {{attempt.number}}",
        "",
        "Description:",
        "{{issue.description}}",
      ];
      if (tpl === "autonomous") {
        return [
          `Implement the ${noun} issue below in this repository.`,
          "",
          ...header,
          "Workspace: {{workspace.path}}",
          "",
          "Make the smallest safe change, run relevant tests, and post a short summary of what you did.",
        ];
      }
      if (tpl === "human-in-the-loop") {
        return [
          `Investigate the ${noun} issue below and prepare a change for human review.`,
          "",
          ...header,
          "Workspace: {{workspace.path}}",
          "",
          "Implement the change in the workspace and run relevant tests, but do not merge or close the issue.",
          "When you are done, write a short review note to {{workspace.path}}/REVIEW.md describing what you changed, what you tested, and any open questions.",
          "Stop after the review note — a human will take it from here.",
        ];
      }
      // reply-draft (non-coding)
      return [
        `Read the ${noun} issue below and draft a friendly, accurate reply for the reporter.`,
        "",
        ...header,
        "",
        "Do not modify any code. Do not transition the issue.",
        "Output the draft reply as your final message — Conduit will post it as a comment for a human to review and send.",
      ];
    }

    function buildWorkflow(): string {
      const hardware = hardwareComment();
      return [
        "---",
        trackerYaml(),
        "workspace:",
        "  root: .conduit/workspaces",
        "  strategy: git-worktree",
        "  base_ref: main",
        runnerYaml(),
        ...(hardware ? [hardware] : []),
        "---",
        ...promptBody(),
      ].join("\n");
    }

    function buildEnv(): string {
      const lines: string[] = [];
      if (state.tracker === "github") lines.push("GITHUB_TOKEN=ghp_...");
      if (state.tracker === "linear") lines.push("LINEAR_API_KEY=lin_api_...");
      if (state.tracker === "jira") {
        lines.push("JIRA_EMAIL=you@example.com");
        lines.push("JIRA_API_TOKEN=...");
      }
      if (state.tracker === "gitlab") lines.push("GITLAB_TOKEN=glpat-...");

      if (state.runner === "claude-api")
        lines.push("ANTHROPIC_API_KEY=sk-ant-...");
      else if (state.runner === "openai-api")
        lines.push("OPENAI_API_KEY=sk-...");
      // claude-cli and codex-cli authenticate via their own CLI tools.
      return lines.join("\n");
    }

    function buildRun(): string {
      return [
        "conduit validate --workflow .conduit/workflow.md",
        "conduit once     --workflow .conduit/workflow.md",
        "conduit start    --workflow .conduit/workflow.md",
      ].join("\n");
    }

    function render() {
      const bm = benchmarkLabel();
      const slots: Record<string, string> = {
        install: buildInstall(),
        workflow: buildWorkflow(),
        env: buildEnv(),
        run: buildRun(),
        "benchmark-model": bm.model,
        "benchmark-tps": bm.tps,
      };
      for (const [key, value] of Object.entries(slots)) {
        const el = root!.querySelector<HTMLElement>(`[data-output="${key}"]`);
        if (el) el.textContent = value;
      }
    }

    repopulateCpuSeries();
    repopulateGpuSeries();
    toggleFields();
    render();
  }
</script>

